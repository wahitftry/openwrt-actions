# Target System
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_redmi-router-ac2100=y

# Pengaturan Bahasa (Set Default English, Hapus Chinese)
CONFIG_LUCI_LANG_en=y
# CONFIG_LUCI_LANG_zh_Hans is not set

# Optimasi Jaringan & Performa Maksimal
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_HWNAT=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_BBR_CCA=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_PDNSD=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_DEFAULT_tcp_bbr=y
CONFIG_PACKAGE_kmod-mt7621-hw-nat=y
CONFIG_PACKAGE_luci-app-flowoffload=y

# Optimasi CPU (Distribusi beban ke 4-threads MT7621)
CONFIG_PACKAGE_irqbalance=y

# Dukungan IPv6
CONFIG_PACKAGE_ipv6helper=y

# Aplikasi LuCI Esensial & Driver WiFi
CONFIG_PACKAGE_luci-app-mtwifi=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-ramfree=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-app-wol=y

# System Utility Tambahan (Sangat ringan)
CONFIG_PACKAGE_htop=y

# Paksa translasi bahasa Inggris untuk LuCI core dan aplikasi
CONFIG_PACKAGE_luci-i18n-base-en=y
CONFIG_PACKAGE_luci-i18n-mtwifi-en=y
CONFIG_PACKAGE_luci-i18n-turboacc-en=y
CONFIG_PACKAGE_luci-i18n-upnp-en=y
CONFIG_PACKAGE_luci-i18n-ttyd-en=y
CONFIG_PACKAGE_luci-i18n-autoreboot-en=y
CONFIG_PACKAGE_luci-i18n-wol-en=y

# CONFIG_PACKAGE_luci-theme-argon is not set

# Pastikan semua paket bahasa Mandarin (zh-cn) dimatikan total
# CONFIG_PACKAGE_luci-i18n-base-zh-cn is not set
# CONFIG_PACKAGE_luci-i18n-mtwifi-zh-cn is not set
# CONFIG_PACKAGE_luci-i18n-turboacc-zh-cn is not set
# CONFIG_PACKAGE_luci-i18n-upnp-zh-cn is not set
# CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn is not set
# CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn is not set
# CONFIG_PACKAGE_luci-i18n-wol-zh-cn is not set

# -----------------------------------------------------
# MENGHAPUS BLOATWARE BAWAAN (Agar CPU/RAM lega)
# -----------------------------------------------------
# CONFIG_PACKAGE_luci-app-adbyby-plus is not set
# CONFIG_PACKAGE_luci-app-unblockmusic is not set
# CONFIG_PACKAGE_luci-app-vsftpd is not set
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_luci-app-vssr is not set
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-ipsec-vpnd is not set
# CONFIG_PACKAGE_luci-app-wireguard is not set
# CONFIG_PACKAGE_luci-app-zerotier is not set
# CONFIG_PACKAGE_luci-app-ddns is not set
# CONFIG_PACKAGE_luci-app-samba4 is not set
# CONFIG_PACKAGE_luci-app-sqm is not set
# CONFIG_PACKAGE_luci-app-qos is not set
